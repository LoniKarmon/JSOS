// stress_test.jsos - Preemption demo: deliberately hogs CPU, shows spin count
import { Window, Keys } from 'libjsos.js';

const W = 400, H = 200;
const win = new Window(200, 150, W, H);

let spinCount = 0;

function spinBusy(iterations) {
    let x = 1;
    for (let i = 0; i < iterations; i++) {
        x = (x * 6364136223846793005 + 1442695040888963407) >>> 0;
    }
    return x;
}

function render() {
    win.rect(0, 0, W, H, 10, 10, 20);
    win.text(10, 20, "Stress Test — Preemption Demo", 255, 255, 100);
    win.text(10, 50, "Spins: " + spinCount, 200, 255, 200);
    win.text(10, 75, "Each spin: ~5M iterations of tight arithmetic", 160, 160, 200);
    win.text(10, 100, "Cursor/taskbar should remain responsive", 160, 200, 160);
    win.text(10, H - 20, "Press Q or Escape to quit", 150, 150, 150);
    win.flush();
}

win.setInterval(50, function() {
    spinBusy(5000000);
    spinCount++;
    render();
});

win.installIpc({
    key:    (c) => { if (Keys.isQuit(c)) os.exit(); },
    render: render,
});

render();
